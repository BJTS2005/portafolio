---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Footer from "../../components/Footer.astro";
import tizaDemo from "../../assets/videos/tiza-demo.webm";
import tizaDashboard from "../../assets/images/tiza-dashboard.png";
import tizaAsistencia from "../../assets/images/tiza-asistencia.png";
import tizaConvivencia from "../../assets/images/tiza-convivencia.png";
import tizaCursos from "../../assets/images/tiza-cursos.png";
---

<Layout title="Tiza — Sistema de Gestión Escolar | Jesus">
    <!-- Efectos de fondo -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <div
            class="absolute -top-40 -right-40 w-96 h-96 bg-accent-cyan/20 rounded-full blur-[128px] animate-pulse-glow"
        >
        </div>
        <div
            class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-violet/10 rounded-full blur-[128px] animate-pulse-glow"
            style="animation-delay: 1s;"
        >
        </div>
    </div>

    <!-- Navbar -->
    <nav
        class="fixed top-0 left-0 right-0 z-50 px-6 py-4 backdrop-blur-md bg-primary/80 border-b border-white/5"
    >
        <div class="max-w-6xl mx-auto flex items-center justify-between">
            <a href="/" class="text-xl font-semibold tracking-tight group">
                <span class="text-accent-cyan">&lt;</span>
                <span
                    class="text-text-primary group-hover:text-accent-purple transition-colors"
                    >Jesus</span
                >
                <span class="text-accent-cyan">/&gt;</span>
            </a>
            <a
                href="/#projects"
                class="text-text-secondary hover:text-accent-cyan transition-colors text-sm flex items-center gap-2"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Volver a proyectos
            </a>
        </div>
    </nav>

    <main class="pt-32 pb-20 px-6">
        <div class="max-w-4xl mx-auto">
            <!-- Header del proyecto -->
            <header class="mb-16">
                <div class="flex items-center gap-4 mb-6">
                    <span
                        class="px-3 py-1 bg-green-500/10 text-green-400 text-xs rounded-full border border-green-500/20"
                    >
                        En Producción
                    </span>
                    <span
                        class="px-3 py-1 bg-accent-cyan/10 text-accent-cyan text-xs rounded-full border border-accent-cyan/20"
                    >
                        U.E. José Acosta Vallejo
                    </span>
                </div>

                <h1
                    class="text-4xl md:text-5xl font-bold text-text-primary mb-4"
                >
                    <span class="text-accent-cyan">Tiza</span> — Gestión Escolar
                </h1>

                <p
                    class="text-text-secondary text-lg leading-relaxed max-w-2xl"
                >
                    Sistema integral de gestión académica <span
                        class="text-green-400">en producción</span
                    > en una institución educativa real: control de acceso basado en roles, notificaciones
                    automáticas por WhatsApp a representantes, panel de convivencia y portal
                    de gestión docente en una sola plataforma.
                </p>
            </header>

            <!-- Aviso de datos ficticios -->
            <div class="mb-12 p-4 bg-amber-500/5 border border-amber-500/20 rounded-xl flex items-start gap-3">
                <svg class="w-5 h-5 text-amber-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-amber-200/80 text-sm leading-relaxed">
                    <span class="font-semibold text-amber-300">Nota:</span> Todos los nombres, datos y registros
                    mostrados en las capturas y el video son completamente ficticios, utilizados
                    únicamente con fines demostrativos.
                </p>
            </div>

            <!-- ───────────────────────────────────────────────── -->
            <!-- WALKTHROUGH / DEMO DEL SISTEMA                     -->
            <div class="relative mb-16 rounded-2xl overflow-hidden border border-white/10">
                <video
                    class="w-full"
                    controls
                    muted
                    loop
                    playsinline
                >
                    <source src={tizaDemo} type="video/webm" />
                </video>
            </div>
            <!-- ───────────────────────────────────────────────── -->

            <!-- Capturas del Sistema -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-3"
                >
                    <span class="text-accent-cyan font-mono text-lg">//</span>
                    Capturas del Sistema
                </h2>

                <div class="grid md:grid-cols-2 gap-4">
                    <div class="group rounded-xl overflow-hidden border border-white/10 bg-surface/30 hover:border-accent-cyan/30 transition-colors">
                        <div class="overflow-hidden">
                            <Image
                                src={tizaDashboard}
                                alt="Panel de administración de Tiza con métricas de estudiantes, docentes y gráficos de asistencia"
                                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                            />
                        </div>
                        <div class="p-4">
                            <h3 class="text-text-primary text-sm font-medium">Panel de Administración</h3>
                            <p class="text-text-muted text-xs mt-1">Dashboard con métricas en tiempo real, gráficos de matrícula y proporción de asistencia.</p>
                        </div>
                    </div>

                    <div class="group rounded-xl overflow-hidden border border-white/10 bg-surface/30 hover:border-green-500/30 transition-colors">
                        <div class="overflow-hidden">
                            <Image
                                src={tizaAsistencia}
                                alt="Toma de asistencia digital con notificación automática por WhatsApp al representante"
                                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                            />
                        </div>
                        <div class="p-4">
                            <h3 class="text-text-primary text-sm font-medium">Asistencia + Notificación WhatsApp</h3>
                            <p class="text-text-muted text-xs mt-1">Al registrar una falta, el representante recibe un mensaje automático al instante.</p>
                        </div>
                    </div>

                    <div class="group rounded-xl overflow-hidden border border-white/10 bg-surface/30 hover:border-accent-violet/30 transition-colors">
                        <div class="overflow-hidden">
                            <Image
                                src={tizaConvivencia}
                                alt="Panel de convivencia DECE con alertas de faltas consecutivas y reportes disciplinarios"
                                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                            />
                        </div>
                        <div class="p-4">
                            <h3 class="text-text-primary text-sm font-medium">Panel de Convivencia (DECE)</h3>
                            <p class="text-text-muted text-xs mt-1">Alertas de faltas consecutivas, ranking de inasistencias y reportes disciplinarios.</p>
                        </div>
                    </div>

                    <div class="group rounded-xl overflow-hidden border border-white/10 bg-surface/30 hover:border-accent-cyan/30 transition-colors">
                        <div class="overflow-hidden">
                            <Image
                                src={tizaCursos}
                                alt="Gestión de cursos, docentes y horarios de clase en Tiza"
                                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                            />
                        </div>
                        <div class="p-4">
                            <h3 class="text-text-primary text-sm font-medium">Cursos, Docentes y Horarios</h3>
                            <p class="text-text-muted text-xs mt-1">Apertura de cursos por año lectivo, asignación de materias y gestión de horarios.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- El Problema -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-3"
                >
                    <span class="text-accent-cyan font-mono text-lg">//</span>
                    El Problema
                </h2>
                <div class="p-6 bg-surface/50 border border-white/5 rounded-xl">
                    <p class="text-text-secondary leading-relaxed">
                        <!-- ⚠️ VERIFICA ESTE PÁRRAFO: los detalles del proceso
                        previo (papel, hojas de cálculo, demoras) deben reflejar
                        cómo lo hacía realmente la institución. Ajusta según el
                        caso real. -->
                        El control de asistencia y el seguimiento disciplinario se
                        llevaban de forma manual, en papel, lo que dificultaba consolidar
                        la información y avisar a tiempo a los representantes. No
                        existía una forma ágil de detectar patrones de inasistencia
                        ni de notificar a las familias cuando un estudiante faltaba
                        o llegaba atrasado.
                    </p>
                </div>
            </section>

            <!-- La Solución -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-3"
                >
                    <span class="text-accent-cyan font-mono text-lg">//</span>
                    La Solución
                </h2>
                <div class="p-6 bg-surface/50 border border-white/5 rounded-xl">
                    <p class="text-text-secondary leading-relaxed">
                        Desarrollé <span class="text-accent-cyan">Tiza</span>,
                        una plataforma web que <span class="text-green-400"
                            >digitaliza la gestión académica de punta a punta</span
                        >. Los docentes toman asistencia desde su portal, y
                        cuando un estudiante registra una falta o atraso, su
                        representante recibe una <span class="text-green-400"
                            >notificación automática por WhatsApp</span
                        > al instante. El departamento de consejería (DECE) cuenta
                        con un panel que detecta automáticamente alertas de faltas
                        consecutivas para intervenir a tiempo.
                    </p>
                </div>
            </section>

            <!-- Funcionalidades -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-3"
                >
                    <span class="text-accent-cyan font-mono text-lg">//</span>
                    Funcionalidades Clave
                </h2>

                <div class="grid md:grid-cols-2 gap-4">
                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:clipboard-check"
                                class="w-5 h-5 text-accent-cyan"
                            />
                            <h3 class="text-text-primary font-medium">
                                Asistencia Digital
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            Toma de asistencia por curso y materia, con estados
                            de presente, falta justificada/injustificada y
                            atraso.
                        </p>
                    </div>

                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:brand-whatsapp"
                                class="w-5 h-5 text-green-400"
                            />
                            <h3 class="text-text-primary font-medium">
                                Notificaciones a Representantes
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            Aviso automático por WhatsApp cuando un estudiante
                            falta o llega atrasado. El representante se entera
                            en el momento.
                        </p>
                    </div>

                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:alert-triangle"
                                class="w-5 h-5 text-accent-violet"
                            />
                            <h3 class="text-text-primary font-medium">
                                Panel de Convivencia (DECE)
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            Detección de alertas de faltas consecutivas y
                            seguimiento de reportes disciplinarios para el
                            departamento de consejería.
                        </p>
                    </div>

                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:school"
                                class="w-5 h-5 text-accent-cyan"
                            />
                            <h3 class="text-text-primary font-medium">
                                Matrículas y Promoción
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            Gestión de matrículas por año lectivo y flujo de
                            promoción de estudiantes al cierre del período.
                        </p>
                    </div>

                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:lock"
                                class="w-5 h-5 text-accent-violet"
                            />
                            <h3 class="text-text-primary font-medium">
                                Control de Acceso por Roles
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            RBAC para administración, docentes y consejería —
                            cada usuario accede solo a lo que le corresponde.
                        </p>
                    </div>

                    <div
                        class="p-5 bg-surface/50 border border-white/5 rounded-xl"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <Icon
                                name="tabler:brand-docker"
                                class="w-5 h-5 text-accent-cyan"
                            />
                            <h3 class="text-text-primary font-medium">
                                Despliegue con Docker
                            </h3>
                        </div>
                        <p class="text-text-muted text-sm">
                            Stack completo orquestado con Docker en 6 servicios
                            contenerizados, en funcionamiento diario.
                        </p>
                    </div>
                </div>
            </section>

            <!-- ════════════════════════════════════════════════ -->
            <!-- ARQUITECTURA — Diagrama de contenedores            -->
            <!-- ════════════════════════════════════════════════ -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-bold text-text-primary mb-6 flex items-center gap-3"
                >
                    <span class="text-accent-cyan font-mono text-lg">//</span>
                    Arquitectura
                </h2>
                <p class="text-text-secondary leading-relaxed mb-6">
                    El sistema corre en <span class="text-text-primary"
                        >6 contenedores Docker</span
                    > dentro de una red interna. Se separa en dos bloques: la aplicación
                    de Tiza (frontend, backend y su base de datos) y un subsistema
                    aislado para las notificaciones de WhatsApp, con su propia base
                    de datos y caché.
                </p>

                <div
                    class="p-4 md:p-6 bg-surface/50 border border-white/5 rounded-xl overflow-x-auto"
                >
                    <svg
                        viewBox="0 0 820 620"
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-full h-auto min-w-[640px]"
                        role="img"
                        aria-label="Diagrama de contenedores Docker del sistema Tiza"
                    >
                        <defs>
                            <marker
                                id="arrow"
                                viewBox="0 0 10 10"
                                refX="8"
                                refY="5"
                                markerWidth="6"
                                markerHeight="6"
                                orient="auto-start-reverse"
                            >
                                <path
                                    d="M 0 0 L 10 5 L 0 10 z"
                                    fill="rgba(255,255,255,0.4)"></path>
                            </marker>
                        </defs>

                        <!-- Red Docker (frame) -->
                        <text
                            x="44"
                            y="86"
                            fill="#00D9FF"
                            font-family="monospace"
                            font-size="12"
                            >// red docker: uejav-network (bridge)</text
                        >
                        <rect
                            x="24"
                            y="94"
                            width="772"
                            height="398"
                            rx="16"
                            fill="rgba(255,255,255,0.015)"
                            stroke="rgba(255,255,255,0.1)"
                            stroke-width="1"></rect>

                        <!-- Usuario (externo, arriba) -->
                        <rect
                            x="300"
                            y="28"
                            width="220"
                            height="44"
                            rx="10"
                            fill="rgba(255,255,255,0.03)"
                            stroke="rgba(255,255,255,0.25)"
                            stroke-width="1.5"></rect>
                        <text
                            x="410"
                            y="55"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">Docente / Navegador</text
                        >

                        <!-- frontend-uejav -->
                        <rect
                            x="300"
                            y="112"
                            width="220"
                            height="54"
                            rx="10"
                            fill="rgba(0,217,255,0.05)"
                            stroke="#00D9FF"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="410"
                            y="136"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">frontend-uejav</text
                        >
                        <text
                            x="410"
                            y="153"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10.5"
                            text-anchor="middle">React + Nginx · :80</text
                        >

                        <!-- backend-uejav -->
                        <rect
                            x="300"
                            y="210"
                            width="220"
                            height="54"
                            rx="10"
                            fill="rgba(0,217,255,0.05)"
                            stroke="#00D9FF"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="410"
                            y="234"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">backend-uejav</text
                        >
                        <text
                            x="410"
                            y="251"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10.5"
                            text-anchor="middle">Express + Prisma · :3000</text
                        >

                        <!-- db-uejav -->
                        <rect
                            x="40"
                            y="322"
                            width="220"
                            height="54"
                            rx="10"
                            fill="rgba(0,217,255,0.05)"
                            stroke="#00D9FF"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="150"
                            y="346"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">db-uejav</text
                        >
                        <text
                            x="150"
                            y="363"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10.5"
                            text-anchor="middle">PostgreSQL · :5434</text
                        >

                        <!-- Subsistema WhatsApp (dashed group) -->
                        <text
                            x="603"
                            y="302"
                            fill="#A855F7"
                            font-family="sans-serif"
                            font-size="11"
                            text-anchor="middle"
                            >Subsistema WhatsApp (Evolution API)</text
                        >
                        <rect
                            x="430"
                            y="308"
                            width="346"
                            height="150"
                            rx="12"
                            fill="rgba(168,85,247,0.04)"
                            stroke="#A855F7"
                            stroke-opacity="0.4"
                            stroke-width="1.5"
                            stroke-dasharray="6 5"></rect>

                        <!-- evo-api-evolution -->
                        <rect
                            x="448"
                            y="322"
                            width="310"
                            height="46"
                            rx="10"
                            fill="rgba(168,85,247,0.06)"
                            stroke="#A855F7"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="603"
                            y="342"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">evo-api-evolution</text
                        >
                        <text
                            x="603"
                            y="358"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10.5"
                            text-anchor="middle">Evolution API · :8080</text
                        >

                        <!-- evo-api-postgres -->
                        <rect
                            x="448"
                            y="394"
                            width="150"
                            height="46"
                            rx="10"
                            fill="rgba(168,85,247,0.06)"
                            stroke="#A855F7"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="523"
                            y="414"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="12"
                            font-weight="600"
                            text-anchor="middle">evo-api-postgres</text
                        >
                        <text
                            x="523"
                            y="430"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10"
                            text-anchor="middle">PostgreSQL</text
                        >

                        <!-- evo-api-redis -->
                        <rect
                            x="608"
                            y="394"
                            width="150"
                            height="46"
                            rx="10"
                            fill="rgba(168,85,247,0.06)"
                            stroke="#A855F7"
                            stroke-opacity="0.55"
                            stroke-width="1.5"></rect>
                        <text
                            x="683"
                            y="414"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="12"
                            font-weight="600"
                            text-anchor="middle">evo-api-redis</text
                        >
                        <text
                            x="683"
                            y="430"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10"
                            text-anchor="middle">Redis · caché</text
                        >

                        <!-- WhatsApp (externo, abajo) -->
                        <rect
                            x="490"
                            y="548"
                            width="230"
                            height="46"
                            rx="10"
                            fill="rgba(74,222,128,0.06)"
                            stroke="#4ADE80"
                            stroke-opacity="0.6"
                            stroke-width="1.5"></rect>
                        <text
                            x="605"
                            y="568"
                            fill="#e2e8f0"
                            font-family="sans-serif"
                            font-size="13"
                            font-weight="600"
                            text-anchor="middle">WhatsApp</text
                        >
                        <text
                            x="605"
                            y="584"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10"
                            text-anchor="middle">→ Representantes</text
                        >

                        <!-- Conexiones -->
                        <!-- usuario → frontend -->
                        <line
                            x1="410"
                            y1="72"
                            x2="410"
                            y2="110"
                            stroke="rgba(255,255,255,0.4)"
                            stroke-width="1.5"
                            marker-end="url(#arrow)"></line>

                        <!-- frontend → backend -->
                        <line
                            x1="410"
                            y1="166"
                            x2="410"
                            y2="208"
                            stroke="rgba(255,255,255,0.4)"
                            stroke-width="1.5"
                            marker-end="url(#arrow)"></line>
                        <text
                            x="420"
                            y="192"
                            fill="#94a3b8"
                            font-family="monospace"
                            font-size="10">proxy /api</text
                        >

                        <!-- backend → db -->
                        <line
                            x1="320"
                            y1="262"
                            x2="170"
                            y2="320"
                            stroke="rgba(255,255,255,0.4)"
                            stroke-width="1.5"
